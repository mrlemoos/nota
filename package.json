{
  "name": "@nota/source",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "engines": {
    "node": ">=22"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mrlemoos/nota.git"
  },
  "scripts": {
    "electron:dev": "nx dev nota-electron",
    "electron:pack": "nx electron:pack nota-electron",
    "release:electron": "nx run @nota/nota-electron:electron:release",
    "dev": "nx run-many -t dev",
    "generate:nota-icons": "node apps/nota/scripts/generate-nota-icons.mjs",
    "test": "nx run-many -t test",
    "postinstall": "husky",
    "format": "nx format:write",
    "lint": "nx run-many -t lint"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "nx exec -- eslint --fix --no-error-on-unmatched-pattern",
      "nx format:write --files"
    ],
    "*.{json,md,mdx,yml,yaml,css,html,astro}": [
      "nx format:write --files"
    ]
  },
  "dependencies": {
    "electron": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@babel/core": "^7.14.5",
