# Copy to .env (or .env.local) — Expo loads EXPO_PUBLIC_* automatically.
# Never commit real secrets.

EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_key_here

# Nota server (for entitlement + future semantic/search). No trailing slash.
EXPO_PUBLIC_NOTA_SERVER_API_URL=http://127.0.0.1:8787

# Optional: if you want a different web checkout target in paywall
# EXPO_PUBLIC_WEB_APP_URL=https://nota.dev
