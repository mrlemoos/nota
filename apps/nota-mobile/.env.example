# Copy to .env (or .env.local) — Expo loads EXPO_PUBLIC_* automatically.
# Never commit real secrets.

EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_key_here

# Supabase (same project as the web app; RLS + Clerk third-party auth)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Nota server (entitlement check). No trailing slash.
EXPO_PUBLIC_NOTA_SERVER_API_URL=http://127.0.0.1:8787

# Web app URL for paywall checkout (Settings / PricingTable on web)
EXPO_PUBLIC_WEB_APP_URL=https://app.nota.mrlemoos.dev
