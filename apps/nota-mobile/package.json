{
  "name": "@nota/nota-mobile",
  "version": "0.0.1",
  "private": true,
  "main": "index.js",
  "nx": {
    "name": "@nota/nota-mobile",
    "sourceRoot": "apps/nota-mobile",
    "projectType": "application",
    "tags": [
      "scope:nota",
      "type:app",
      "platform:mobile"
    ],
    "targets": {
      "ensure-symlink": {
        "executor": "@nx/expo:ensure-symlink"
      },
      "sync-deps": {
        "executor": "@nx/expo:sync-deps"
      }
    }
  },
  "scripts": {
    "start": "expo start --ios",
    "dev": "expo start --ios --clear",
    "dev:ios": "expo start --ios --clear",
    "dev:android": "expo start --android --clear",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "dependencies": {
    "@10play/tentap-editor": "*",
    "@clerk/expo": "^3.2.0",
    "@expo/metro-config": "~54.0.16",
    "@expo/metro-runtime": "~6.1.2",
    "@nota/database-types": "workspace:*",
    "@nota/internal-note-link": "workspace:*",
    "@nota/mobile-editor": "workspace:*",
    "@nota/note-editor-settings": "workspace:*",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/source-serif-4": "catalog:",
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/instrument-serif": "catalog:",
    "expo-font": "~14.0.12",
    "@nota/nota-server-client": "workspace:*",
    "@nota/note-link-graph": "workspace:*",
    "@nota/notes-offline-core": "workspace:*",
    "@nota/validation": "workspace:*",
    "@supabase/supabase-js": "catalog:",
    "expo": "~54.0.0",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "metro": "~0.83.0",
    "metro-config": "~0.83.0",
    "metro-resolver": "~0.83.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-webview": "13.15.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@expo/cli": "~54.0.16",
    "@types/react": "~19.1.10",
    "getenv": "^2.0.0",
    "typescript": "catalog:"
  },
  "expo": {
    "router": {
      "root": "./app"
    }
  }
}
