# Clerk (same instance as the SPA)
CLERK_SECRET_KEY=

# xAI — assistive audio-to-note (`POST /api/audio-to-note`) and Semantic Search embeddings (`POST /api/semantic-search`)
XAI_API_KEY=
# Optional; default on server is grok-3
# XAI_CHAT_MODEL=grok-3
#
# Semantic Search — Grok embedding model id from xAI Console / docs (`POST https://api.x.ai/v1/embeddings`)
XAI_EMBEDDING_MODEL=
# Must match Postgres `vector(N)` in migration `note_semantic_index.embedding` (default 1536)
# XAI_EMBEDDING_DIMENSIONS=1536
# Optional override of the Inference API origin (defaults to https://api.x.ai/v1)
# XAI_API_BASE=https://api.x.ai/v1

# Supabase — semantic index reads/writes (`note_semantic_index`) via service role (server only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
