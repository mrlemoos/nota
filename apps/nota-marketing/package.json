{
  "name": "@nota/nota-marketing",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build && node scripts/verify-marketing-hero.mjs",
    "preview": "astro preview",
    "generate:og": "node scripts/generate-og.mjs",
    "generate:favicons": "node scripts/generate-favicons.mjs"
  },
  "dependencies": {
    "@nota/web-design": "workspace:*",
    "@astrojs/sitemap": "^3.7.2",
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/instrument-serif": "catalog:",
    "@microsoft/clarity": "^1.0.2",
    "@nx/eslint": "catalog:",
    "@nx/eslint-plugin": "catalog:",
    "@nx/react": "catalog:",
    "@nx/web": "catalog:",
    "@vercel/analytics": "^1.5.0",
    "astro": "^6.1.0",
    "electron": "catalog:",
    "jsdom": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "tailwindcss": "catalog:",
    "to-ico": "^1.0.1",
    "typescript": "catalog:"
  },
  "nx": {
    "tags": [
      "scope:nota",
      "type:app",
      "platform:web"
    ],
    "targets": {
      "dev": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "apps/nota-marketing",
          "command": "astro dev"
        }
      },
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "apps/nota-marketing",
          "command": "pnpm run build"
        }
      },
      "preview": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "apps/nota-marketing",
          "command": "astro preview"
        }
      }
    }
  }
}
