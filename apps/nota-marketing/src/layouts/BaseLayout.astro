---
import Analytics from '@vercel/analytics/astro';
import {
  MKT_THEME_COLOR_META_ID,
  MKT_THEME_COLOR_PAGE,
  chromeSchemeForThemeColor,
} from '@/lib/marketing-theme';

/** Marketing body is always light; dark hero chrome uses `.mkt-dark` / sticky header hex. */
const BODY_BACKGROUND_HEX = MKT_THEME_COLOR_PAGE;
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  /** Path from site root, e.g. `/og/home.png`; defaults to `/og-default.png` */
  image?: string;
  ogTitle?: string;
  ogDescription?: string;
  /** Defaults to `Astro.url.pathname` */
  canonicalPath?: string;
  /** Browser chrome colour; defaults to light page background. */
  themeColor?: string;
  /** Open Graph type; use `article` for blog posts. */
  ogType?: 'website' | 'article';
}

const OG_IMAGE_WIDTH = 1200;
const OG_IMAGE_HEIGHT = 630;

const {
  title = 'Nota — Mac Note-Taking App for Focused Writing',
  description =
    'Nota is a native Mac app for writing and linking notes — calm, minimal, offline-first. No feeds, no nudges. Just your thoughts.',
  image = '/og-default.png',
  ogTitle,
  ogDescription,
  canonicalPath,
  themeColor = MKT_THEME_COLOR_PAGE,
  ogType = 'website',
} = Astro.props;

const site = Astro.site;
if (!site) {
  throw new Error('BaseLayout requires `site` in astro.config so Open Graph URLs are absolute.');
}

const pathForCanonical = canonicalPath ?? Astro.url.pathname;
const canonicalUrl = new URL(pathForCanonical, site).href;
const imageUrl = new URL(image, site).href;

const socialTitle = ogTitle ?? title;
const socialDescription = ogDescription ?? description;
const chromeScheme = chromeSchemeForThemeColor(themeColor);
---

<!doctype html>
<html lang="en-GB" class={chromeScheme}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta
      id={MKT_THEME_COLOR_META_ID}
      name="theme-color"
      content={themeColor}
    />
    <style is:inline set:html={`body{background-color:${BODY_BACKGROUND_HEX}}`} />
    <script
      is:inline
      define:vars={{ themeColor, chromeScheme, metaId: MKT_THEME_COLOR_META_ID }}
    >
      (function () {
        var root = document.documentElement;
        root.classList.remove('light', 'dark');
        root.classList.add(chromeScheme);
        var meta = document.getElementById(metaId);
        if (meta) {
          meta.setAttribute('content', themeColor);
          meta.removeAttribute('media');
        }
        document
          .querySelectorAll('meta[name="theme-color"][media]')
          .forEach(function (node) {
            node.remove();
          });
      })();
    </script>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Nota" />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={socialDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content={String(OG_IMAGE_WIDTH)} />
    <meta property="og:image:height" content={String(OG_IMAGE_HEIGHT)} />
    <meta property="og:locale" content="en_GB" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={socialDescription} />
    <meta name="twitter:image" content={imageUrl} />

    <link rel="icon" href="/favicon.ico" type="image/x-icon" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <Analytics />
    <script>
      import Clarity from '@microsoft/clarity';

      const projectId = import.meta.env.VITE_CLARITY_PROJECT_ID;
      if (typeof projectId === 'string' && projectId.length > 0) {
        Clarity.init(projectId);
      }
    </script>
    <slot name="head-extras" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
