---
import BlogPostCard from '@/components/BlogPostCard.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { isBlogPostPublished, sortBlogPostsByDate } from '@/lib/blog';
import { getCollection } from 'astro:content';

const site = Astro.site;
if (!site) {
  throw new Error('Marketing site requires `site` in astro.config.');
}
const siteRoot = new URL('/', site).href;
const blogUrl = new URL('/blog', site).href;

const pageTitle = 'Blog — Nota';
const pageDescription =
  'Product updates and notes on building a calm Mac notes app. Occasional essays from the Nota team.';

const posts = sortBlogPostsByDate(
  (await getCollection('blog')).filter(isBlogPostPublished),
);

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: siteRoot },
        { '@type': 'ListItem', position: 2, name: 'Blog', item: blogUrl },
      ],
    },
    {
      '@type': 'Blog',
      name: 'Nota blog',
      description: pageDescription,
      url: blogUrl,
      publisher: { '@type': 'Organization', name: 'Nota', url: siteRoot },
    },
  ],
};
---

<BaseLayout title={pageTitle} description={pageDescription} canonicalPath="/blog">
  <script type="application/ld+json" slot="head-extras" is:inline set:html={JSON.stringify(structuredData)} />
  <main id="main-content">
    <SiteHeader />
    <div class="mx-auto max-w-3xl px-6 py-16 md:px-10 md:py-24">
      <header class="mb-12">
        <h1 class="font-serif text-4xl font-normal text-foreground md:text-5xl">Blog</h1>
        <p class="mt-4 max-w-2xl text-lg text-muted-foreground">
          Product updates and occasional notes on calm note-taking for Mac.
        </p>
      </header>

      {
        posts.length === 0 ? (
          <p class="text-muted-foreground">No posts yet. Check back soon.</p>
        ) : (
          <div>
            {posts.map((post) => (
              <BlogPostCard post={post} />
            ))}
          </div>
        )
      }

      <p class="mt-14 text-center text-sm text-muted-foreground">
        <a href="/" class="mkt-focus underline decoration-border underline-offset-4 hover:text-foreground">
          ← Home
        </a>
      </p>
    </div>
  </main>
</BaseLayout>
