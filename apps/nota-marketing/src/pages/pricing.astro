---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DownloadMacButton from '@/components/DownloadMacButton.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import { MKT_THEME_COLOR_PAGE } from '@/lib/marketing-theme';

const site = Astro.site;
if (!site) {
  throw new Error('Marketing site requires `site` in astro.config.');
}
const siteRoot = new URL('/', site).href;
const pricingUrl = new URL('/pricing', site).href;

/** Guide amounts; keep in sync with Clerk Billing / Stripe (USD). */
const priceMonthlyUsd = '2.49';
const priceAnnualUsd = '19.49';
const priceAnnualMonthlyUsd = (Number.parseFloat(priceAnnualUsd) / 12).toFixed(2);

const pricingTitle = 'Nota Pricing — From $2.49/month';
const pricingDescription =
  'Nota is a paid Mac notes app: subscribe in-app for cloud sync and backup. Guide prices $19.49/year or $2.49/month (USD); lifetime offered when available in checkout.';

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        {
          '@type': 'ListItem',
          position: 1,
          name: 'Home',
          item: siteRoot,
        },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Pricing',
          item: pricingUrl,
        },
      ],
    },
    {
      '@type': 'SoftwareApplication',
      name: 'Nota',
      operatingSystem: 'macOS',
      applicationCategory: 'ProductivityApplication',
      description:
        'Native Mac notes app. Subscribe inside the app after install for full access, cloud sync, and backup.',
      url: siteRoot,
      offers: [
        {
          '@type': 'Offer',
          name: 'Nota — annual',
          price: priceAnnualUsd,
          priceCurrency: 'USD',
          description: 'Full app access; billed annually. Subscribe from Settings in the macOS app.',
          availability: 'https://schema.org/OnlineOnly',
          url: pricingUrl,
        },
        {
          '@type': 'Offer',
          name: 'Nota — monthly',
          price: priceMonthlyUsd,
          priceCurrency: 'USD',
          description: 'Full app access; billed monthly. Subscribe from Settings in the macOS app.',
          availability: 'https://schema.org/OnlineOnly',
          url: pricingUrl,
        },
      ],
    },
  ],
};
---

<BaseLayout
  image="/og/pricing.png"
  title={pricingTitle}
  description={pricingDescription}
  themeColor={MKT_THEME_COLOR_PAGE}
>
  <script type="application/ld+json" slot="head-extras" is:inline set:html={JSON.stringify(structuredData)} />
  <main id="main-content">
    <SiteHeader />
    <div class="mx-auto max-w-5xl px-6 py-16 md:px-10 md:py-24">
      <h1 class="mb-4 font-serif text-4xl font-normal text-foreground md:text-5xl">Pricing</h1>
      <p class="mb-14 max-w-2xl text-sm text-muted-foreground">
        Figures below are in <span class="text-foreground/90">US Dollars</span>; taxes may apply by region.
      </p>

      <div class="grid gap-14 md:grid-cols-3 md:gap-x-12 md:gap-y-0 lg:gap-x-16">
        <article class="flex flex-col">
          <h2 class="font-serif text-2xl font-normal text-foreground">Annual</h2>
          <p class="mt-3 text-3xl font-semibold tracking-tight text-foreground">
            {'$' + priceAnnualMonthlyUsd}
            <span class="text-xl font-normal text-muted-foreground"> / month</span>
          </p>
          <p class="mt-1 text-sm text-muted-foreground">Billed annually</p>
          <p class="mt-4 text-sm font-medium text-foreground">Save about 35% vs monthly</p>
          <ul class="mt-6 space-y-2 text-sm leading-relaxed text-muted-foreground">
            <li>Full app access</li>
            <li>Cloud sync and secure backup</li>
            <li>Use on the devices where you sign in</li>
          </ul>
        </article>

        <article class="flex flex-col">
          <h2 class="font-serif text-2xl font-normal text-foreground">Monthly</h2>
          <p class="mt-3 text-3xl font-semibold tracking-tight text-foreground">
            {'$' + priceMonthlyUsd}
            <span class="text-xl font-normal text-muted-foreground"> / month</span>
          </p>
          <ul class="mt-8 space-y-2 text-sm leading-relaxed text-muted-foreground">
            <li>Same features as annual</li>
            <li>Cancel through your billing provider</li>
          </ul>
        </article>

        <article class="flex flex-col">
          <h2 class="font-serif text-2xl font-normal text-foreground">Lifetime</h2>
          <p class="mt-3 text-3xl font-semibold tracking-tight text-foreground">In-app</p>
          <p class="mt-6 text-sm leading-relaxed text-muted-foreground">
            When offered in your build of Nota, lifetime is a one-time purchase alongside monthly and yearly.
          </p>
        </article>
      </div>

      <div class="mt-16 border-t border-border pt-10 text-center">
        <DownloadMacButton class="mkt-btn--compact" />
        <p class="mt-4 text-sm text-muted-foreground">
          <a
            href="/refunds"
            class="mkt-focus font-medium text-foreground underline decoration-border underline-offset-4 hover:text-foreground"
            >Refund policy</a
          >
          for web-billed subscriptions.
        </p>
      </div>

      <p class="mt-14 text-center text-sm text-muted-foreground">
        <a href="/" class="mkt-focus underline decoration-border underline-offset-4 hover:text-foreground">← Back home</a>
      </p>
    </div>
  </main>
</BaseLayout>
