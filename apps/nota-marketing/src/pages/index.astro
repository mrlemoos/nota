---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DownloadMacButton from '@/components/DownloadMacButton.astro';
import SiteHeader from '@/components/SiteHeader.astro';
import { MKT_THEME_COLOR_HERO } from '@/lib/marketing-theme';
import { NOTA_GITHUB_LATEST, NOTA_GITHUB_RELEASES, NOTA_GITHUB_REPO } from '@/lib/site';

const site = Astro.site;
if (!site) {
  throw new Error('Marketing site requires `site` in astro.config.');
}
const siteRoot = new URL('/', site).href;
const heroScreenshot = '/desktop-app-screenshot.png';
const downloadUrl = NOTA_GITHUB_LATEST;

/** Guide amounts; keep in sync with `pricing.astro` and Clerk Billing (USD). */
const priceMonthlyUsd = '2.49';
const priceAnnualUsd = '19.49';

const homeTitle = 'Nota — Quiet Mac Notes';
const homeDescription =
  'A native Mac notes app that protects your attention. No feeds, no nudges—just a calm place to write and link ideas. Subscribe in-app after install.';

const faqEntities = [
  {
    '@type': 'Question',
    name: 'Is there a free tier or trial?',
    acceptedAnswer: {
      '@type': 'Answer',
      text:
        'No. Download the Mac app from GitHub Releases, create an account, then subscribe in Settings to use Nota. USD guide prices are on the pricing page; checkout in the app shows the final charge.',
    },
  },
  {
    '@type': 'Question',
    name: 'What does a subscription include?',
    acceptedAnswer: {
      '@type': 'Answer',
      text:
        'Full access to writing, the note graph, attachments, and cloud sync with secure backup across devices where you use Nota while signed in.',
    },
  },
];

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteRoot}#organization`,
      name: 'Nota',
      url: siteRoot,
      sameAs: [NOTA_GITHUB_REPO],
    },
    {
      '@type': 'WebSite',
      '@id': `${siteRoot}#website`,
      url: siteRoot,
      name: 'Nota',
      description: homeDescription,
      publisher: { '@id': `${siteRoot}#organization` },
    },
    {
      '@type': 'SoftwareApplication',
      '@id': `${siteRoot}#software`,
      name: 'Nota',
      operatingSystem: 'macOS',
      applicationCategory: 'ProductivityApplication',
      description: homeDescription,
      url: siteRoot,
      downloadUrl,
      screenshot: new URL(heroScreenshot, site).href,
      author: {
        '@type': 'Person',
        name: 'Leonardo Lemos',
        url: 'https://mrlemoos.dev',
      },
      publisher: { '@id': `${siteRoot}#organization` },
      offers: [
        {
          '@type': 'Offer',
          name: 'Nota — monthly',
          price: priceMonthlyUsd,
          priceCurrency: 'USD',
          description:
            'Full app access with cloud sync and backup. Billed monthly; subscribe from inside the macOS app after install.',
          availability: 'https://schema.org/OnlineOnly',
          url: `${siteRoot}pricing`,
        },
        {
          '@type': 'Offer',
          name: 'Nota — annual',
          price: priceAnnualUsd,
          priceCurrency: 'USD',
          description:
            'Full app access with cloud sync and backup. Billed annually; subscribe from inside the macOS app after install.',
          availability: 'https://schema.org/OnlineOnly',
          url: `${siteRoot}pricing`,
        },
      ],
    },
    {
      '@type': 'FAQPage',
      '@id': `${siteRoot}#faq`,
      mainEntity: faqEntities,
    },
  ],
};

const heroScreenshotAlt =
  'Nota on macOS over a soft cityscape: dark glass sidebar, serif note title, and a calm writing surface without feeds or nudges';
---

<BaseLayout
  title={homeTitle}
  description={homeDescription}
  image="/og/home.png"
  themeColor={MKT_THEME_COLOR_HERO}
>
  <script type="application/ld+json" slot="head-extras" is:inline set:html={JSON.stringify(structuredData)} />
  <main id="main-content">
    <div class="mkt-dark mkt-hero-shell overflow-hidden">
      <SiteHeader borderless />

      <section
        class="relative z-10 mx-auto flex max-w-6xl flex-col gap-16 px-6 pb-16 pt-16 md:gap-20 md:px-10 md:pb-20 md:pt-20 lg:gap-24"
        aria-labelledby="hero-heading"
      >
        <div class="mx-auto flex max-w-2xl flex-col items-center gap-10 text-center md:gap-12 lg:max-w-3xl">
          <h1
            id="hero-heading"
            class="font-serif text-4xl font-normal leading-[1.1] text-balance text-foreground md:text-5xl lg:text-[3.25rem]"
          >
            Think without the feed.
          </h1>
          <p class="text-base leading-relaxed text-muted-foreground md:text-lg">
            A native Mac notes app for writing and linking ideas. Nota steps back when you pause.<br />
            <span class="text-foreground">No performance, no nudges.</span>
          </p>
          <div
            class="flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-5"
            id="download"
          >
            <DownloadMacButton class="mkt-hero-fade mkt-hero-fade-delay-1" />
            <a
              href="/pricing"
              class="mkt-hero-fade mkt-hero-fade-delay-2 mkt-focus inline-flex min-h-11 items-center justify-center px-2 py-3 text-sm font-medium text-muted-foreground underline decoration-muted-foreground/40 underline-offset-4 transition hover:text-foreground"
            >
              Pricing
            </a>
          </div>
          <p class="text-sm leading-relaxed text-muted-foreground/90">
            Install from GitHub Releases, sign in, subscribe in Settings.
          </p>
        </div>

        <figure class="mkt-hero-fade mkt-hero-fade-delay-3 mx-auto w-full max-w-5xl">
          <div
            class="mkt-hero-screenshot-frame overflow-hidden rounded-xl border border-border/80 bg-card/20 p-1.5 shadow-[0_32px_90px_-24px_rgba(0,0,0,0.65)] ring-1 ring-white/10"
          >
            <img
              src={heroScreenshot}
              alt={heroScreenshotAlt}
              width={2828}
              height={1854}
              class="h-auto w-full rounded-[calc(var(--radius)-2px)]"
              data-nota-hero-screenshot
              loading="eager"
              decoding="async"
              fetchpriority="high"
            />
          </div>
        </figure>
      </section>
    </div>

    <section
      id="faq"
      class="border-t border-border bg-background px-6 py-16 md:px-10 md:py-20"
      aria-labelledby="faq-heading"
    >
      <div class="mx-auto max-w-xl">
        <h2 id="faq-heading" class="mb-10 font-serif text-2xl font-normal text-foreground md:text-3xl">
          Common questions
        </h2>
        <dl class="space-y-8 text-sm md:text-base">
          <div>
            <dt class="font-medium text-foreground">Is there a free tier or trial?</dt>
            <dd class="mt-2 leading-relaxed text-muted-foreground">
              No. Download the Mac app from
              <a
                href={NOTA_GITHUB_RELEASES}
                class="mkt-focus underline decoration-border underline-offset-4 hover:text-foreground"
                >GitHub Releases</a
              >, sign in, and subscribe in Settings to write and sync. See
              <a href="/pricing" class="mkt-focus underline decoration-border underline-offset-4 hover:text-foreground"
                >pricing</a
              > for current USD guide prices.
            </dd>
          </div>
          <div>
            <dt class="font-medium text-foreground">What does a subscription include?</dt>
            <dd class="mt-2 leading-relaxed text-muted-foreground">
              Writing, internal links, the note graph, attachments, and cloud sync with backup while you are signed in.
            </dd>
          </div>
        </dl>
      </div>
    </section>

    <footer class="bg-background px-6 py-12 md:px-10 md:py-14">
      <div class="mx-auto max-w-6xl text-center">
        <p class="font-serif text-xl text-foreground">Ready when you are.</p>
        <p class="mt-2 text-sm text-muted-foreground">Download for Mac. Subscribe when it suits you.</p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row sm:gap-4">
          <DownloadMacButton
            class="mkt-focus inline-flex min-h-11 min-w-[12rem] items-center justify-center gap-2 rounded-[var(--radius)] bg-primary px-6 py-3 text-sm font-medium text-primary-foreground transition hover:opacity-90"
          />
          <a
            href="/pricing"
            class="mkt-focus inline-flex min-h-11 min-w-[12rem] items-center justify-center rounded-[var(--radius)] border border-border px-6 py-3 text-sm font-medium text-foreground transition hover:bg-muted"
          >
            View pricing
          </a>
        </div>
      </div>
      <div
        class="mx-auto mt-10 flex max-w-6xl flex-col items-center gap-4 text-center text-sm text-muted-foreground sm:flex-row sm:flex-wrap sm:justify-center sm:gap-x-10 sm:gap-y-3 md:flex-col md:items-end md:justify-end md:text-right md:gap-3"
      >
        <p>
          <a
            href={NOTA_GITHUB_REPO}
            class="mkt-focus underline decoration-border underline-offset-4 hover:text-foreground"
            rel="noopener noreferrer"
            target="_blank">Open source</a
          >
          ·
          <a href="/pricing" class="mkt-focus underline decoration-border underline-offset-4 hover:text-foreground"
            >Pricing</a
          >
          ·
          <a href="/refunds" class="mkt-focus underline decoration-border underline-offset-4 hover:text-foreground"
            >Refunds</a
          >
        </p>
        <p>
          Copyright &copy; 2026{' '}
          <a
            href="https://mrlemoos.dev"
            class="mkt-focus underline decoration-border underline-offset-4 hover:text-foreground"
            rel="noopener noreferrer"
            target="_blank">mrlemoos.dev</a
          >. All rights reserved.
        </p>
      </div>
    </footer>
  </main>
</BaseLayout>
