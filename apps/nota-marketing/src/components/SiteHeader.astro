---
import GitHubIcon from '@/components/GitHubIcon.astro';
import { NOTA_GITHUB_LATEST, NOTA_GITHUB_REPO } from '@/lib/site';

interface Props {
  borderless?: boolean;
}

const { borderless = false } = Astro.props;
---

<header
  class:list={[
    'sticky top-0 z-50 bg-background/80 px-5 py-4 text-foreground backdrop-blur-md md:px-8',
    !borderless && 'border-b border-border/60',
  ]}
>
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-6">
    <a href="/" class="mkt-focus font-serif text-xl tracking-tight text-foreground"> Nota </a>
    <nav class="flex flex-wrap items-center justify-end gap-x-6 gap-y-2 text-sm font-medium">
      <a href={NOTA_GITHUB_LATEST} class="mkt-focus text-muted-foreground transition hover:text-foreground">
        Download
      </a>
      <a href="/blog" class="mkt-focus text-muted-foreground transition hover:text-foreground"> Blog </a>
      <a href="/pricing" class="mkt-focus text-muted-foreground transition hover:text-foreground"> Pricing </a>
      <a href="/#faq" class="mkt-focus text-muted-foreground transition hover:text-foreground"> FAQ </a>
      <a
        href={NOTA_GITHUB_REPO}
        class="mkt-focus inline-flex size-9 items-center justify-center rounded-[var(--radius-sm)] text-muted-foreground transition hover:bg-muted hover:text-foreground"
        rel="noopener noreferrer"
        target="_blank"
        aria-label="Nota on GitHub"
      >
        <GitHubIcon />
      </a>
    </nav>
  </div>
</header>
