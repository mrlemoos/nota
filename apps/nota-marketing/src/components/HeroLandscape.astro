---
/* Decorative monochrome landscape; matches the sign-in screen mood. */
---

<svg
  class="pointer-events-none absolute inset-0 z-0 h-full w-full opacity-40"
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 1200 640"
  preserveAspectRatio="xMidYMid slice"
  aria-hidden="true"
>
  <defs>
    <linearGradient id="mkt-hero-sky" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0%" stop-color="#ffffff" stop-opacity="0.16"></stop>
      <stop offset="55%" stop-color="#ffffff" stop-opacity="0.06"></stop>
      <stop offset="100%" stop-color="#ffffff" stop-opacity="0"></stop>
    </linearGradient>
  </defs>
  <rect width="1200" height="640" fill="url(#mkt-hero-sky)"></rect>
  <circle cx="980" cy="120" r="36" fill="#ffffff" fill-opacity="0.2"></circle>
  <ellipse cx="820" cy="118" rx="52" ry="14" fill="#ffffff" fill-opacity="0.11"></ellipse>
  <ellipse cx="760" cy="132" rx="40" ry="11" fill="#ffffff" fill-opacity="0.09"></ellipse>
  <ellipse cx="280" cy="100" rx="64" ry="16" fill="#ffffff" fill-opacity="0.09"></ellipse>
  <ellipse cx="220" cy="118" rx="48" ry="12" fill="#ffffff" fill-opacity="0.07"></ellipse>
  <path
    d="M0 420 Q 200 360 420 400 T 840 380 T 1200 400 L 1200 640 L 0 640 Z"
    fill="#ffffff"
    fill-opacity="0.13"></path>
  <path
    d="M0 460 Q 280 400 520 440 T 1000 420 T 1200 450 L 1200 640 L 0 640 Z"
    fill="#ffffff"
    fill-opacity="0.19"></path>
  <path d="M0 500 Q 340 460 600 490 T 1200 480 L 1200 640 L 0 640 Z" fill="#ffffff" fill-opacity="0.26"></path>
</svg>
