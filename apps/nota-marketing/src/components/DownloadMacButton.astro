---
import AppleIcon from '@/components/AppleIcon.astro';
import { NOTA_GITHUB_LATEST } from '@/lib/site';

interface Props {
  class?: string;
}

const defaultClass = 'mkt-focus mkt-btn mkt-btn--primary';

const { class: className } = Astro.props;
---

<a href={NOTA_GITHUB_LATEST} class:list={[defaultClass, className]}>
  <AppleIcon />
  Download for macOS
</a>
