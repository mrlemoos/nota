---
import AppleIcon from '@/components/AppleIcon.astro';
import { NOTA_GITHUB_LATEST } from '@/lib/site';

interface Props {
  class?: string;
}

const defaultClass =
  'mkt-focus inline-flex min-h-11 min-w-[12rem] items-center justify-center gap-2 rounded-[var(--radius)] bg-primary px-6 py-3 text-sm font-medium text-primary-foreground shadow-sm transition hover:opacity-90';

const { class: className } = Astro.props;
---

<a href={NOTA_GITHUB_LATEST} class:list={[defaultClass, className]}>
  <AppleIcon />
  Download for macOS
</a>
