{
  "name": "@nota/editor",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "@nota/source": {
        "types": "./src/index.ts",
        "import": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "nx": {
    "tags": [
      "scope:nota",
      "type:feature",
      "platform:web"
    ],
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "packages/editor",
          "command": "pnpm run build"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json"
  },
  "dependencies": {
    "@nota/database-types": "workspace:*",
    "@nota/internal-note-link": "workspace:*",
    "@nota/web-design": "workspace:*",
    "@tiptap/extension-code-block": "^2.11.5",
    "@tiptap/extension-code-block-lowlight": "2.11.5",
    "@tiptap/extension-emoji": "^2.27.2",
    "@tiptap/extension-highlight": "2.27.2",
    "@tiptap/extension-link": "^3.23.4",
    "@tiptap/extension-placeholder": "^2.11.5",
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/extension-task-item": "^2.27.2",
    "@tiptap/extension-task-list": "^2.27.2",
    "@tiptap/pm": "^2.11.5",
    "@tiptap/react": "^2.11.5",
    "@tiptap/starter-kit": "^2.11.5",
    "@tiptap/suggestion": "2.27.2",
    "chrono-node": "^2.9.0",
    "lowlight": "^3.3.0",
    "mermaid": "^11.12.0",
    "pdfjs-dist": "^5.5.207",
    "react-day-picker": "^9.14.0",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "react": "^19.0.3",
    "react-dom": "^19.0.3"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
