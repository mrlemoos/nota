{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./out-tsc/vitest",
    "types": [
      "vitest/globals",
      "vitest/importMeta",
      "vite/client",
      "node",
      "vitest"
    ],
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": [
    "vite.config.mts",
    "src/**/*.spec.ts",
    "src/lib/fixtures/**/*.json"
  ],
  "references": [{ "path": "./tsconfig.lib.json" }]
}
