{
  "name": "@nota/web-design",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    "./button": {
      "@nota/source": "./src/components/button.tsx",
      "types": "./dist/components/button.d.ts",
      "import": "./dist/button.js",
      "default": "./dist/button.js"
    },
    "./card": {
      "@nota/source": "./src/components/card.tsx",
      "types": "./dist/components/card.d.ts",
      "import": "./dist/card.js",
      "default": "./dist/card.js"
    },
    "./tooltip": {
      "@nota/source": "./src/components/tooltip.tsx",
      "types": "./dist/components/tooltip.d.ts",
      "import": "./dist/tooltip.js",
      "default": "./dist/tooltip.js"
    },
    "./context-menu": {
      "@nota/source": "./src/components/context-menu.tsx",
      "types": "./dist/components/context-menu.d.ts",
      "import": "./dist/context-menu.js",
      "default": "./dist/context-menu.js"
    },
    "./spinner": {
      "@nota/source": "./src/components/spinner.tsx",
      "types": "./dist/components/spinner.d.ts",
      "import": "./dist/spinner.js",
      "default": "./dist/spinner.js"
    },
    "./nota-tint-circle": {
      "@nota/source": "./src/components/nota-tint-circle.tsx",
      "types": "./dist/components/nota-tint-circle.d.ts",
      "import": "./dist/nota-tint-circle.js",
      "default": "./dist/nota-tint-circle.js"
    },
    "./utils": {
      "@nota/source": "./src/lib/utils.ts",
      "types": "./dist/lib/utils.d.ts",
      "import": "./dist/utils.js",
      "default": "./dist/utils.js"
    },
    "./theme": {
      "@nota/source": "./src/lib/theme.tsx",
      "types": "./dist/lib/theme.d.ts",
      "import": "./dist/theme.js",
      "default": "./dist/theme.js"
    }
  },
  "peerDependencies": {
    "@nota/helper-hooks": "workspace:*",
    "react": "^19.0.3",
    "react-dom": "^19.0.3"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:"
  },
  "nx": {
    "tags": [
      "scope:nota",
      "type:ui",
      "platform:web"
    ],
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "^build"
        ],
        "outputs": [
          "{projectRoot}/dist"
        ],
        "options": {
          "cwd": "packages/web-design",
          "command": "vite build && pnpm exec tsc -b tsconfig.lib.json"
        }
      }
    }
  }
}
