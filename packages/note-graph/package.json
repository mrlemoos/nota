{
  "name": "@nota/note-graph",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "@nota/source": {
        "types": "./src/index.ts",
        "import": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "nx": {
    "tags": [
      "scope:nota",
      "type:feature",
      "platform:web"
    ],
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "packages/note-graph",
          "command": "pnpm run build"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json"
  },
  "dependencies": {
    "@nota/database-types": "workspace:*",
    "@nota/editor": "workspace:*",
    "@nota/i18n": "workspace:*",
    "@nota/note-link-graph": "workspace:*",
    "@nota/web-design": "workspace:*",
    "@xyflow/react": "^12.10.1",
    "react": "catalog:"
  },
  "peerDependencies": {
    "react-dom": "catalog:"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.0",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "jsdom": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  }
}
