{
  "name": "@nota/mobile-editor",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "nx": {
    "tags": [
      "scope:nota",
      "type:feature",
      "platform:mobile"
    ],
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "cwd": "packages/mobile-editor",
          "command": "pnpm run build"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.lib.json"
  },
  "dependencies": {
    "@nota/database-types": "workspace:*",
    "@nota/notes-offline-core": "workspace:*",
    "@nota/internal-note-link": "workspace:*",
    "@nota/note-link-graph": "workspace:*",
    "@nota/validation": "workspace:*",
    "@10play/tentap-editor": "^0.6.0"
  },
  "peerDependencies": {
    "react": "catalog:",
    "react-native": ">=0.76.0",
    "react-native-webview": "^13.0.0"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "react-native": ">=0.76.0",
    "@types/react": "catalog:",
    "react-native-webview": "^13.0.0"
  }
}
