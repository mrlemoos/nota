{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "src",
    "outDir": "dist",
    "jsx": "react-jsx",
    "lib": ["ES2020"],
    "moduleResolution": "bundler",
    "types": ["react-native", "node"],
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "out-tsc",
    "dist",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.spec.tsx",
    "**/*.test.tsx"
  ],
  "references": [
    {
      "path": "../validation/tsconfig.lib.json"
    },
    {
      "path": "../note-link-graph/tsconfig.lib.json"
    },
    {
      "path": "../internal-note-link/tsconfig.lib.json"
    },
    {
      "path": "../notes-offline-core/tsconfig.lib.json"
    },
    {
      "path": "../database-types/tsconfig.lib.json"
    }
  ]
}
